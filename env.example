# ============================================================
# SUPABASE (PostgreSQL Database)
# ============================================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ============================================================
# AWS S3 (Image Storage)
# ============================================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY=AKIA...
AWS_SECRET_KEY=wJal...
S3_BUCKET=bigshopper-scraper-xxxxx

# ============================================================
# REDIS (Job Queue)
# ============================================================
REDIS_URL=redis://default:password@containers.railway.app:6379

# ============================================================
# SCRAPER CONFIG
# ============================================================
PARALLEL_WORKERS=5
IMAGES_PER_PAGE=10
SCRAPE_TIMEOUT=30000

# ============================================================
# SERVER
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# SCHEDULING
# ============================================================
# Cron format: minute hour day month weekday
# Daily at 2:00 AM: 0 2 * * *
# Every 6 hours: 0 */6 * * *
SCRAPE_SCHEDULE=0 2 * * *
